<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AnalysisLevel>latest</AnalysisLevel>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>
  <PropertyGroup>
    <Authors>Korgys</Authors>
    <Company>Korgys</Company>
    <Product>WebBundler</Product>
    <Description>Lightweight bundling and minification for .NET web projects without JavaScript toolchains.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>dotnet;bundling;minification;msbuild;cli;css;javascript</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Korgys/WebBundler</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Korgys/WebBundler</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
  </PropertyGroup>
  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)README.MD" Pack="true" PackagePath="README.md" Visible="false" />
  </ItemGroup>
</Project>
